# WhosGotStock Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/whosgotstock
DATABASE_SSL=false  # Set to 'true' for production with SSL

# PostgreSQL Credentials (for Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whosgotstock

# Application
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
TEAM_ACCESS_CODE=your-team-access-code
MANAGEMENT_ACCESS_CODE=your-management-access-code
ADMIN_ACCESS_CODE=your-admin-access-code

# Supplier API Credentials
ESQUIRE_EMAIL=your-esquire-email@example.com
ESQUIRE_PASSWORD=your-esquire-password
MUSTEK_CUSTOMER_TOKEN=your-mustek-customer-token
SYNTECH_API_KEY=your-syntech-api-key
PINNACLE_UID=your-pinnacle-uid
PINNACLE_API_KEY=your-pinnacle-api-key

# Evenflow Configuration
EVENFLOW_API_URL=https://api.evenflow.com/v1
EVENFLOW_API_KEY=your-evenflow-api-key

# Worker Configuration
UPDATE_INTERVAL_MINUTES=60
